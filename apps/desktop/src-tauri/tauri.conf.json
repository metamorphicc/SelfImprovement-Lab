{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Self Improvement Labs",
  "version": "0.1.0",
  "identifier": "com.selfimprovementlabs.desktop",
  "build": {
    "beforeDevCommand": "npm --workspace @sil/web run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --workspace @sil/web run build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Self Improvement Labs",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Self Improvement Labs",
    "copyright": "Copyright 2026 Self Improvement Labs. All rights reserved.",
    "category": "Productivity",
    "icon": [
      "icons/icon.ico"
    ],
    "shortDescription": "A private desktop RPG system for real-life progression.",
    "longDescription": "An offline-first personal command center for profile progression, quests, skills, knowledge, inventory, wallets, daily history, and backups.",
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English", "Russian"],
        "displayLanguageSelector": true,
        "startMenuFolder": "Self Improvement Labs"
      }
    }
  }
}
